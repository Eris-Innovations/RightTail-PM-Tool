# --- Database (Supabase Postgres) ----------------------------------------
# Server-side connection string -- Supabase **transaction pooler** (port
# 6543, IPv4-friendly). Get it from:
#   Supabase Dashboard -> Settings -> Database -> "Connection string" ->
#   "Transaction" mode.
# Replace any URL-reserved password characters with their percent-encoded
# equivalents: # -> %23, $ -> %24, ! -> %21, @ -> %40, etc.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# --- Frontend Supabase client --------------------------------------------
# Exposed to the browser (Next.js only inlines NEXT_PUBLIC_* env vars).
# The publishable key is safe to ship to clients -- it has no privileged
# access, and Supabase only honours its scope through Supabase Auth flows
# + RLS (when enabled).
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME

# --- Server-only Supabase secret -----------------------------------------
# Used by /api/auth/signup (server-side admin createUser, bypasses public
# rate limit + auto-confirms email) and /scripts/seed-user.mjs. NEVER
# expose to the browser. Get it from the same project's API settings as
# the publishable key above -- the "service_role" row in legacy Project
# API Keys.
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJ...

# --- Vercel Cron (optional) ---------------------------------------------
# Shared secret sent by Vercel Cron as
#   Authorization: Bearer ${CRON_SECRET}
# Required only if you want the daily deadline-reminder cron defined in
# vercel.json to bypass the admin/manager session check. Generate any
# high-entropy random string (e.g. `openssl rand -hex 32`) and set it on
# the Vercel project as well as in this .env if you ever want to call
# the endpoint locally with the same header.
# CRON_SECRET=replace-with-a-long-random-string

# --- Optional knobs ------------------------------------------------------
# ACTIVE_USER_WINDOW_DAYS=30
# UPCOMING_DEADLINE_DAYS=14
# MAIL_DRIVER=console        # console | off | (future: smtp / sendgrid / ses)
